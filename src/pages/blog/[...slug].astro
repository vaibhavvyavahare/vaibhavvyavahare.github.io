---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar';
import Contact from '../../components/Contact';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<Layout title={post.data.title}>
  <Navbar client:load />
  
  <article class="max-w-3xl mx-auto px-6 pt-32 pb-16 text-white">
    <div class="mb-10 text-center">
      <span class="text-blue-500 font-medium tracking-wide uppercase text-sm">{post.data.category}</span>
      <h1 class="text-4xl md:text-5xl font-bold mt-4 mb-6 leading-tight">{post.data.title}</h1>
      <div class="text-gray-400 flex justify-center gap-4">
        <span>{post.data.date}</span>
        <span>•</span>
        <span>{post.data.author}</span>
      </div>
    </div>

    <div class="prose prose-invert prose-lg mx-auto bg-white/5 p-8 rounded-3xl border border-white/10">
      <Content />
    </div>
  </article>

  <Contact client:visible />
</Layout>
