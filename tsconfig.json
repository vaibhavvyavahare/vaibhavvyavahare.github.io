{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": false,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "allowJs": true,
    "noEmit": true,
    "esModuleInterop": true
  },
  "include": [
    "docs/.vuepress/**/*.js",
    "docs/.vuepress/**/*.ts",
    "docs/.vuepress/**/*.vue",
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules"
  ]
}